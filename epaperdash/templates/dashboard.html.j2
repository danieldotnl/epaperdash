<!doctype html>
<html lang="nl">
<head>
<meta charset="utf-8">
<title>Keukendashboard</title>
<style>
  :root {
    --ink: #000;
    --ink-2: #000;   /* panel is 1-bit B/W in ESPHome — no native gray */
    --ink-3: #000;
    --paper: #fff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    width: 800px;
    height: 480px;
    background: var(--paper);
    color: var(--ink);
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-weight: 500;
    -webkit-font-smoothing: none;
    font-smooth: never;
  }
  .page {
    width: 800px;
    height: 480px;
    display: grid;
    grid-template-rows: 110px 1fr 54px;
  }

  /* ─── hero header: "right now" ─── */
  header {
    border-bottom: 2px solid var(--ink);
    padding: 14px 24px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    column-gap: 24px;
  }
  header .date-block .weekday {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1;
  }
  header .date-block .date {
    font-size: 18px;
    font-weight: 600;
    color: var(--ink-2);
    margin-top: 6px;
  }
  header .weather-block {
    display: grid;
    grid-template-columns: auto auto;
    align-items: center;
    column-gap: 18px;
  }
  header .weather-block .glyph {
    font-size: 72px;
    line-height: 1;
    font-weight: 700;
    font-variant-emoji: text;
  }
  header .weather-block .stats {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  header .weather-block .stats .now {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  header .weather-block .stats .temp {
    font-size: 40px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -1px;
  }
  header .weather-block .stats .cond {
    font-size: 18px;
    font-weight: 700;
  }
  header .weather-block .stats .range,
  header .weather-block .stats .wind {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-2);
  }

  /* ─── body: two columns ─── */
  .body {
    display: grid;
    grid-template-columns: 1fr 2px 300px;
    border-bottom: 2px solid var(--ink);
    min-height: 0;
  }
  .col-divider { background: var(--ink); }
  .pane {
    padding: 12px 20px;
    overflow: hidden;
  }
  .pane h2 {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--ink-2);
    margin-bottom: 6px;
  }

  /* ── left pane: agenda ── */
  .agenda-block { margin-bottom: 10px; }
  .agenda-block:last-child { margin-bottom: 0; }
  .agenda-block .head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    border-bottom: 1px solid var(--ink-3);
    padding-bottom: 3px;
    margin-bottom: 6px;
  }
  .agenda-block .head .lbl {
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 0.5px;
  }
  .agenda-block .head .sub {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-2);
    flex: 1;
  }
  .agenda-block .head .wx {
    font-size: 13px;
    font-weight: 700;
    color: var(--ink-2);
  }
  .agenda-block .ev {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    column-gap: 8px;
    align-items: baseline;
    padding: 2px 0;
  }
  .agenda-block .ev .icon {
    font-size: 14px;
    font-weight: 700;
    text-align: center;
  }
  .agenda-block .ev .title {
    font-size: 15px;
    font-weight: 700;
  }
  .agenda-block .ev .when {
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-2);
    font-variant-numeric: tabular-nums;
  }
  .agenda-block .empty {
    font-size: 13px;
    font-style: italic;
    color: var(--ink-3);
    padding: 2px 0;
  }

  /* week list (compact rows under DEZE WEEK) */
  .week-row {
    display: grid;
    grid-template-columns: 82px 18px 1fr auto;
    column-gap: 8px;
    align-items: baseline;
    padding: 3px 0;
    border-bottom: 1px solid var(--ink-3);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .week-row:last-child { border-bottom: none; }
  .week-row .day-stamp {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink-2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .week-row .icon {
    font-size: 13px;
    font-weight: 700;
    text-align: center;
  }
  .week-row .title {
    font-size: 14px;
    font-weight: 700;
  }
  .week-row .when {
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-2);
  }

  /* ── right pane: panels ── */
  .pane-right {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .panel {
    display: flex;
    flex-direction: column;
  }
  .panel .row {
    display: grid;
    grid-template-columns: 88px 1fr;
    column-gap: 8px;
    align-items: baseline;
    padding: 3px 0;
    border-bottom: 1px solid var(--ink-3);
    font-variant-numeric: tabular-nums;
  }
  .panel .row:last-child { border-bottom: none; }
  .panel .row .when {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink-2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .panel .row .what {
    font-size: 14px;
    font-weight: 700;
  }
  .panel .row .what .age {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-2);
  }

  /* ─── footer ─── */
  footer {
    padding: 8px 22px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  footer .badge {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 4px 8px;
    border: 2px solid var(--ink);
    white-space: nowrap;
  }
  footer .fact {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.3;
    flex: 1;
  }
</style>
</head>
<body>
{% set icons = {"calendar": "◆", "school": "✎", "waste": "♻", "holiday": "★"} %}
<div class="page">

  <header>
    <div class="date-block">
      <div class="weekday">{{ header.weekday }}</div>
      <div class="date">{{ header.date }}</div>
    </div>
    <div class="weather-block">
      <div class="glyph">{{ header.weather.icon }}</div>
      <div class="stats">
        <div class="now">
          <span class="temp">{{ header.weather.temp_high }}°</span>
          <span class="cond">{{ header.weather.condition }}</span>
        </div>
        <div class="range">min {{ header.weather.temp_low }}° · {{ header.weather.wind }}</div>
      </div>
    </div>
  </header>

  <div class="body">

    <section class="pane pane-left">
      <div class="agenda-block">
        <div class="head">
          <div class="lbl">VANDAAG</div>
        </div>
        {% if today_events %}
          {% for ev in today_events %}
          <div class="ev">
            <div class="icon">{{ icons[ev.cat] }}</div>
            <div class="title">{{ ev.title }}</div>
            <div class="when">{{ ev.time }}</div>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty">— geen afspraken —</div>
        {% endif %}
      </div>

      <div class="agenda-block">
        <div class="head">
          <div class="lbl">MORGEN</div>
          <div class="sub">{{ tomorrow.weekday_short }} {{ tomorrow.date_short }}</div>
          <div class="wx">{{ tomorrow.weather_icon }} {{ tomorrow.temp_high }}</div>
        </div>
        {% if tomorrow.events %}
          {% for ev in tomorrow.events %}
          <div class="ev">
            <div class="icon">{{ icons[ev.cat] }}</div>
            <div class="title">{{ ev.title }}</div>
            <div class="when">{{ ev.time }}</div>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty">— geen afspraken —</div>
        {% endif %}
      </div>

      <div class="agenda-block">
        <div class="head">
          <div class="lbl">DEZE WEEK</div>
        </div>
        {% if week_rows %}
          {% for r in week_rows %}
          <div class="week-row">
            <div class="day-stamp">{{ r.weekday_short }} {{ r.date_short }}</div>
            <div class="icon">{{ icons[r.cat] }}</div>
            <div class="title">{{ r.title }}</div>
            <div class="when">{{ r.time }}</div>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty">— geen afspraken —</div>
        {% endif %}
      </div>
    </section>

    <div class="col-divider"></div>

    <section class="pane pane-right">
      <div class="panel">
        <h2>Afval</h2>
        {% for r in recycling %}
        <div class="row">
          <div class="when">{{ r.date }}</div>
          <div class="what">{{ r.type }}</div>
        </div>
        {% endfor %}
      </div>

      <div class="panel">
        <h2>Verjaardagen</h2>
        {% for b in birthdays %}
        <div class="row">
          <div class="when">{{ b.date }}</div>
          <div class="what">
            {{ b.name }}{% if b.age %} <span class="age">({{ b.age }})</span>{% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </section>

  </div>

  <footer>
    <div class="badge">Wist je dat?</div>
    <div class="fact">{{ fact|safe }}</div>
  </footer>

</div>
</body>
</html>
