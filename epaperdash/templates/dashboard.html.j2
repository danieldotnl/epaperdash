<!doctype html>
<html lang="nl">
<head>
<meta charset="utf-8">
<title>Keukendashboard</title>
<style>
  :root {
    --ink: #000;
    --ink-2: #555;   /* 60% — secondary text, allowed by 4-level gray panel */
    --ink-3: #aaa;   /* 30% — rules, tertiary */
    --paper: #fff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    width: 800px;
    height: 480px;
    background: var(--paper);
    color: var(--ink);
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-weight: 500;
    -webkit-font-smoothing: none;
    font-smooth: never;
  }
  .page {
    width: 800px;
    height: 480px;
    display: grid;
    grid-template-rows: 64px 1fr 56px;
  }

  /* ─── header ─── */
  header {
    border-bottom: 2px solid var(--ink);
    padding: 12px 22px 10px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  header .weekday {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1;
  }
  header .date {
    font-size: 18px;
    font-weight: 600;
    color: var(--ink-2);
  }
  header .weather {
    font-size: 18px;
    font-weight: 600;
  }
  header .weather .temp {
    font-size: 22px;
    font-weight: 800;
  }

  /* ─── body: two columns ─── */
  .body {
    display: grid;
    grid-template-columns: 1fr 2px 1fr;
    border-bottom: 2px solid var(--ink);
  }
  .col {
    padding: 12px 20px;
    overflow: hidden;
  }
  .col-divider {
    background: var(--ink);
  }
  .col h2 {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--ink-2);
    margin-bottom: 8px;
  }

  /* ── left column: today + tomorrow detail ── */
  .detail-day {
    margin-bottom: 14px;
  }
  .detail-day:last-child { margin-bottom: 0; }
  .detail-day .day-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    border-bottom: 1px solid var(--ink-3);
    padding-bottom: 4px;
    margin-bottom: 8px;
  }
  .detail-day .day-head .lbl {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 0.5px;
  }
  .detail-day .day-head .sub {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-2);
    flex: 1;
  }
  .detail-day .day-head .wx {
    font-size: 13px;
    font-weight: 700;
    color: var(--ink-2);
  }
  .detail-day .ev {
    display: grid;
    grid-template-columns: 22px 1fr;
    column-gap: 8px;
    padding: 4px 0;
  }
  .detail-day .ev .icon {
    font-size: 16px;
    line-height: 1.2;
    font-weight: 700;
    text-align: center;
  }
  .detail-day .ev .title {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.15;
  }
  .detail-day .ev .when {
    grid-column: 2;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-2);
    margin-top: 1px;
  }
  .detail-day .ev.is-birthday .title { font-weight: 800; }
  .detail-day .empty {
    font-size: 13px;
    font-style: italic;
    color: var(--ink-3);
    padding: 4px 0;
  }

  /* ── right column: compact week ── */
  .compact-day {
    display: grid;
    grid-template-columns: 64px 1fr;
    column-gap: 10px;
    padding: 6px 0;
    border-bottom: 1px solid var(--ink-3);
  }
  .compact-day:last-child { border-bottom: none; }
  .compact-day .stamp {
    text-align: center;
    line-height: 1;
  }
  .compact-day .stamp .wd {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--ink-2);
  }
  .compact-day .stamp .dt {
    font-size: 22px;
    font-weight: 800;
    margin-top: 2px;
    font-variant-numeric: tabular-nums;
  }
  .compact-day .stamp .wx {
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-2);
    margin-top: 3px;
  }
  .compact-day .evs {
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-self: center;
  }
  .compact-day .evs .row {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    column-gap: 6px;
    align-items: baseline;
    font-size: 14px;
    line-height: 1.2;
  }
  .compact-day .evs .row .icon {
    font-weight: 700;
    text-align: center;
  }
  .compact-day .evs .row .title {
    font-weight: 700;
  }
  .compact-day .evs .row .when {
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-2);
    font-variant-numeric: tabular-nums;
  }
  .compact-day .evs .row.is-birthday .title { font-weight: 800; }

  /* ─── footer ─── */
  footer {
    padding: 8px 22px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  footer .badge {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 4px 8px;
    border: 2px solid var(--ink);
    white-space: nowrap;
  }
  footer .fact {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    flex: 1;
  }
</style>
</head>
<body>
{# Icon glyphs per category. Kept here so the template stays declarative. #}
{% set icons = {"birthday": "✿", "recycling": "♻", "calendar": "▣", "school": "✎"} %}
<div class="page">

  <header>
    <div class="weekday">{{ header.weekday }}</div>
    <div class="date">{{ header.date }}</div>
    <div class="weather">
      <span class="temp">{{ header.temp }}°</span>
      <span>{{ header.condition }}</span>
    </div>
  </header>

  <div class="body">

    <section class="col col-left">
      <h2>Vandaag &amp; morgen</h2>
      {% for d in days[:2] %}
      <div class="detail-day">
        <div class="day-head">
          <div class="lbl">{{ d.label }}</div>
          <div class="sub">{{ d.weekday_short }} {{ d.date_short }}</div>
          <div class="wx">{{ d.weather_icon }} {{ d.temp_high }}</div>
        </div>
        {% if d.events %}
          {% for ev in d.events %}
          <div class="ev {% if ev.cat == 'birthday' %}is-birthday{% endif %}">
            <div class="icon">{{ icons[ev.cat] }}</div>
            <div class="title">{{ ev.title }}</div>
            <div class="when">{{ ev.time if ev.time else "Hele dag" }}</div>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty">— geen afspraken —</div>
        {% endif %}
      </div>
      {% endfor %}
    </section>

    <div class="col-divider"></div>

    <section class="col col-right">
      <h2>Deze week</h2>
      {% for d in days[2:] %}
      <div class="compact-day">
        <div class="stamp">
          <div class="wd">{{ d.weekday_short }}</div>
          <div class="dt">{{ d.date_short.split(' ')[0] }}</div>
          <div class="wx">{{ d.weather_icon }} {{ d.temp_high }}</div>
        </div>
        <div class="evs">
          {% for ev in d.events %}
          <div class="row {% if ev.cat == 'birthday' %}is-birthday{% endif %}">
            <div class="icon">{{ icons[ev.cat] }}</div>
            <div class="title">{{ ev.title }}</div>
            <div class="when">{{ ev.time if ev.time else "hele dag" }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </section>

  </div>

  <footer>
    <div class="badge">Wist je dat?</div>
    <div class="fact">{{ fact|safe }}</div>
  </footer>

</div>
</body>
</html>
