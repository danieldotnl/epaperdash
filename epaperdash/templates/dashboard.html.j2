<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Kitchen Dashboard</title>
<style>
  :root {
    --ink: #000;
    --paper: #fff;
    --rule: #000;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    width: 800px;
    height: 480px;
    background: var(--paper);
    color: var(--ink);
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-weight: 500;
    -webkit-font-smoothing: none;
    font-smooth: never;
  }
  .page {
    width: 800px;
    height: 480px;
    display: grid;
    grid-template-rows: 90px 1fr 70px;
    grid-template-columns: 1fr;
  }

  header {
    border-bottom: 3px solid var(--rule);
    padding: 14px 24px 12px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  header .day {
    font-size: 44px;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1;
  }
  header .date {
    font-size: 22px;
    font-weight: 600;
  }

  .body {
    display: grid;
    grid-template-columns: 1fr 320px;
    border-bottom: 3px solid var(--rule);
  }
  .calendar {
    padding: 14px 22px;
    border-right: 3px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .calendar h2,
  .weather h2 {
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding-bottom: 4px;
    border-bottom: 2px solid var(--rule);
    margin-bottom: 4px;
  }
  .event {
    display: grid;
    grid-template-columns: 78px 1fr;
    column-gap: 14px;
    align-items: baseline;
  }
  .event .time {
    font-size: 18px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .event .title {
    font-size: 19px;
    font-weight: 600;
    line-height: 1.2;
  }
  .event .meta {
    grid-column: 2;
    font-size: 14px;
    font-weight: 500;
    color: #000;
    opacity: 0.7;
  }

  .weather {
    padding: 14px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .weather .now {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 2px;
  }
  .weather .temp {
    font-size: 64px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -2px;
  }
  .weather .cond {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.2;
  }
  .weather .range {
    font-size: 14px;
    font-weight: 500;
    opacity: 0.75;
  }
  .forecast {
    margin-top: 6px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    border-top: 2px solid var(--rule);
    padding-top: 8px;
  }
  .forecast .cell { text-align: center; }
  .forecast .cell .when {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .forecast .cell .ic {
    font-size: 22px;
    line-height: 1.1;
    font-weight: 700;
    font-variant-emoji: text;
  }
  .forecast .cell .t {
    font-size: 13px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  footer {
    padding: 10px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  footer .badge {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 4px 8px;
    border: 2px solid var(--rule);
  }
  footer .fact {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.25;
    flex: 1;
  }
</style>
</head>
<body>
<div class="page">

  <header>
    <div class="day">{{ day }}</div>
    <div class="date">{{ date }}</div>
  </header>

  <div class="body">

    <section class="calendar">
      <h2>Today's Agenda</h2>
      {% for event in events %}
      <div class="event">
        <div class="time">{{ event.time }}</div>
        <div class="title">{{ event.title }}</div>
        <div class="meta">{{ event.meta }}</div>
      </div>
      {% endfor %}
    </section>

    <section class="weather">
      <h2>Weather</h2>
      <div class="now">
        <div class="temp">{{ weather.temp }}&deg;</div>
        <div>
          <div class="cond">{{ weather.condition }}</div>
          <div class="range">{{ weather.range }}</div>
        </div>
      </div>

      <div class="forecast">
        {% for cell in weather.forecast %}
        <div class="cell">
          <div class="when">{{ cell.when }}</div>
          <div class="ic">{{ cell.icon }}</div>
          <div class="t">{{ cell.temp }}</div>
        </div>
        {% endfor %}
      </div>
    </section>

  </div>

  <footer>
    <div class="badge">Did you know?</div>
    <div class="fact">{{ fact|safe }}</div>
  </footer>

</div>
</body>
</html>
